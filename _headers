/*

  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Prevent site from being embedded in iframes
  X-Frame-Options: SAMEORIGIN

  # Enforce HTTPS (after testing on short duration)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Protect referrer information
  Referrer-Policy: strict-origin-when-cross-origin

  # Minimal CSP to allow most ai-folio features (edit as needed)
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests; connect-src 'self' https://www.googletagmanager.com https://plausible.io; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://badge.dimensions.ai; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://badge.dimensions.ai https://www.googletagmanager.com https://plausible.io https://d1bxh8uas1mnw7.cloudfront.net https://static.cloudflareinsights.com;

  # Optional (prevents caching sensitive pages)
  Cache-Control: no-store
